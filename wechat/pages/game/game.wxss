/* 弹弹塔 — 明亮暖色主题 */
page{width:100%;height:100%;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'PingFang SC',sans-serif;background:#fef9f0}

canvas{width:100%;height:100%;position:absolute;top:0;left:0;z-index:0}

/* 遮罩 */
.mask{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;justify-content:center;align-items:center;z-index:10;background:rgba(254,249,240,0.85)}
.mask-dark{background:rgba(254,249,240,0.92)}
.mask-light{background:rgba(254,249,240,0.7)}
.gameover-overlay{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;justify-content:center;align-items:center;z-index:10}

/* 首页 */
.home-header{padding:44px 0 20px;text-align:center}
.home-logo{font-size:52px;margin-bottom:2px;animation:logoBounce 2s ease-in-out infinite}
@keyframes logoBounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.home-title{font-size:36px;font-weight:900;color:#e8734a;letter-spacing:8px;text-shadow:0 2px 4px rgba(232,115,74,0.1)}
.home-slogan{font-size:14px;color:#999;margin:4px 0 12px;letter-spacing:3px}

.btn-start{display:block;width:68%;max-width:260px;margin:0 auto 20px;padding:18px 0;border-radius:60px;font-size:22px;font-weight:800;letter-spacing:4px;text-align:center;color:#fff;border:none;
  background:linear-gradient(135deg,#ff6b6b,#ff8e53,#ffa500);box-shadow:0 8px 32px rgba(255,107,107,0.4);animation:startGlow 2s ease-in-out infinite}
@keyframes startGlow{0%,100%{box-shadow:0 8px 32px rgba(255,107,107,0.4)}50%{box-shadow:0 8px 52px rgba(255,107,107,0.65)}}
.btn-start:active{transform:scale(0.93)}

/* 进度条 */
.progress-bar{width:72%;max-width:280px;margin:0 auto 18px;display:flex;align-items:center;gap:10px}
.progress-fill{flex:1;height:8px;background:#f0e8dc;border-radius:4px;overflow:hidden}
.progress-inner{height:100%;border-radius:4px;background:linear-gradient(90deg,#ff6b6b,#ffa500);transition:width 0.5s}
.progress-text{font-size:13px;font-weight:700;color:#999;white-space:nowrap}

/* 关卡网格 */
.lv-section{width:90%;max-width:360px;margin:0 auto 14px}
.lv-section-title{font-size:14px;font-weight:700;color:#b0a89a;letter-spacing:2px;margin-bottom:10px;text-align:center}
.lv-grid{display:flex;flex-wrap:wrap;gap:9px;justify-content:center;padding:2px}
.lv-item{width:54px;height:68px;border-radius:14px;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#fff;border:2px solid #f0e8dc;position:relative;box-shadow:0 2px 8px rgba(0,0,0,0.04)}
.lv-item:active{transform:scale(0.9)}
.lv-item.cleared{background:#f0fdf4;border-color:#86efac}
.lv-item.perfect{background:#fffef0;border-color:#fbbf24;box-shadow:0 0 14px rgba(251,191,36,0.2)}
.lv-item.current{border-color:#ff6b6b;box-shadow:0 0 0 3px rgba(255,107,107,0.25);animation:curPulse 1.5s ease-in-out infinite}
.lv-item.locked{opacity:0.25;background:#fafaf7}
@keyframes curPulse{0%,100%{box-shadow:0 0 0 3px rgba(255,107,107,0.25)}50%{box-shadow:0 0 0 6px rgba(255,107,107,0.1)}}
.lv-num{font-size:19px;font-weight:900;color:#555}
.lv-target{font-size:8px;color:#b0a89a;margin-top:1px}
.lv-stars{font-size:8px;margin-top:1px}
.lv-rate{font-size:8px;color:#ff6b6b;font-weight:700;margin-top:1px}
.lv-lock{font-size:12px;margin-top:1px;opacity:0.4}

/* 每日挑战卡片 */
.daily-card{width:86%;max-width:360px;margin:0 auto 14px;padding:14px 18px;border-radius:18px;
  background:linear-gradient(135deg,#fff8ed,#fff3e0);border:2px solid #ffcc80;display:flex;align-items:center;box-shadow:0 4px 16px rgba(255,150,0,0.08)}
.daily-card:active{background:#fff3e0;transform:scale(0.98)}
.daily-icon{font-size:30px;margin-right:12px}
.daily-info{flex:1}
.daily-label{font-size:14px;font-weight:700;color:#e67e00;letter-spacing:1px}
.daily-desc{font-size:11px;color:#b0a090}
.daily-arrow{font-size:16px;color:#d0c0a0}

/* 底部按钮行 */
.home-btns{display:flex;gap:8px;width:86%;max-width:360px;margin:4px auto 0;padding-bottom:40px}
.home-btns .btn-sm{flex:1}

/* 弹窗面板 */
.panel{background:#fff;border-radius:24px;padding:30px 24px 20px;display:flex;flex-direction:column;align-items:center;box-shadow:0 12px 48px rgba(0,0,0,0.1);width:82%;max-width:330px}
.panel-title{font-size:22px;font-weight:800;color:#555;letter-spacing:2px;margin-bottom:6px}
.panel-score{font-size:56px;font-weight:900;background:linear-gradient(180deg,#ff6b6b,#ff8e53);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.1}
.panel-newbest{font-size:15px;font-weight:700;color:#ff6b6b;margin:4px 0;animation:pulse 0.8s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
.panel-detail{font-size:12px;color:#999;margin:4px 0 14px}
.panel-hint{font-size:17px;font-weight:700;color:#ff6b35;margin:6px 0}
.panel-stars{font-size:38px;margin:6px 0;letter-spacing:4px}
.panel-stars .empty{opacity:0.12}

/* 按钮 */
.btn{width:100%;padding:14px 0;border-radius:50px;font-size:16px;font-weight:700;letter-spacing:2px;margin-bottom:10px;border:none;text-align:center}
.btn:active{transform:scale(0.95)}
.btn::after{border:none}
.btn-gold{background:linear-gradient(135deg,#f7971e,#ffd200);color:#fff;box-shadow:0 6px 24px rgba(247,151,30,0.3)}
.btn-green{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;box-shadow:0 6px 24px rgba(34,197,94,0.25)}
.btn-red{background:linear-gradient(135deg,#ff6b6b,#ee5a24);color:#fff;box-shadow:0 6px 24px rgba(255,107,107,0.3)}
.btn-outline{background:#fafaf7;color:#888;border:1.5px solid #e8e0d0!important}
.btn-sm{padding:12px 0;font-size:13px;letter-spacing:1px;margin-bottom:0}

/* 道具栏 */
.toolbar{position:absolute;right:14px;bottom:130px;z-index:5;display:flex;flex-direction:column;gap:10px;pointer-events:none}
.tool-btn{pointer-events:auto;width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,0.85);border:2px solid #e8e0d0;display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:0 2px 12px rgba(0,0,0,0.06)}
.tool-btn:active{transform:scale(0.85);background:#fff;border-color:#ff6b6b}
.tool-btn.empty{opacity:0.25}
.tool-icon{font-size:20px}
.tool-count{font-size:10px;font-weight:700;color:#999}

/* 成就 */
.achieve-toast{position:absolute;top:12%;left:50%;transform:translateX(-50%);z-index:30;animation:popIn 0.5s cubic-bezier(0.175,0.885,0.32,1.275),popOut 0.3s ease-in 2.2s forwards}
@keyframes popIn{from{opacity:0;transform:translateX(-50%) scale(0.6) translateY(-20px)}to{opacity:1;transform:translateX(-50%) scale(1) translateY(0)}}
@keyframes popOut{from{opacity:1}to{opacity:0}}
.achieve-card{background:#fff;border-radius:18px;padding:16px 28px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,0.1);border:2px solid #fbbf24}
.achieve-icon{font-size:40px;margin-bottom:2px}
.achieve-name{font-size:18px;font-weight:800;color:#555;letter-spacing:2px}
.achieve-desc{font-size:11px;color:#999}

/* 排行 */
.sheet{background:#fff;border-radius:22px;padding:22px 16px 14px;display:flex;flex-direction:column;box-shadow:0 12px 48px rgba(0,0,0,0.1);width:86%;max-width:360px;max-height:72%}
.sheet-title{font-size:19px;font-weight:800;color:#555;text-align:center;letter-spacing:2px;margin-bottom:12px}
.sheet-list{flex:1;max-height:320px;overflow-y:auto}
.rank-item{display:flex;align-items:center;padding:9px 10px;border-radius:12px;margin-bottom:3px}
.rank-item:nth-child(1){background:#fffdf5}
.rank-item:nth-child(2){background:#fafaf8}
.rank-item:nth-child(3){background:#fdf7f3}
.rank-num{width:28px;text-align:center;font-size:15px;font-weight:900;color:#ccc}
.rank-item:nth-child(1) .rank-num{color:#ffd700;font-size:20px}
.rank-item:nth-child(2) .rank-num{color:#b0b0b0;font-size:18px}
.rank-item:nth-child(3) .rank-num{color:#cd7f32;font-size:17px}
.rank-avatar{width:30px;height:30px;border-radius:50%;margin:0 10px;background:#f0f0f0}
.rank-name{flex:1;font-size:13px;color:#555;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.rank-score{font-size:14px;font-weight:800;color:#ff6b6b}

/* 皮肤 */
.skin-item{display:flex;align-items:center;padding:10px 12px;margin-bottom:6px;border-radius:14px;border:1.5px solid #f0e8dc;background:#fafaf7}
.skin-item:active{background:#f5f0e8}
.skin-item.active{border-color:#ff6b6b;background:#fff5f5}
.skin-item.locked{opacity:0.45}
.skin-swatch{display:flex;gap:4px;margin-right:12px}
.skin-swatch .dot{width:18px;height:18px;border-radius:5px}
.skin-name{font-size:13px;color:#555;font-weight:600;flex:1}
.skin-badge{font-size:10px;color:#b0a090}
.skin-badge.free{color:#4ade80;font-weight:600}
